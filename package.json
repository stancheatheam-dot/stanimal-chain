{
  "name": "stanimal-chain",
  "version": "1.0.0",
  "description": "Stanimal Chain — Proof of Stake supply chain blockchain with STAN token",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "node1": "HTTP_PORT=3001 P2P_PORT=6001 node src/index.js",
    "node2": "HTTP_PORT=3002 P2P_PORT=6002 PEERS=ws://localhost:6001 node src/index.js",
    "node3": "HTTP_PORT=3003 P2P_PORT=6003 PEERS=ws://localhost:6001,ws://localhost:6002 node src/index.js",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
